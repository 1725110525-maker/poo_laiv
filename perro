class Perro:
        def __init__(self, nombre, raza, color, edad, peso, tamano, genero, tipo_pelo, nivel_energia, dueno):
                self.nombre = nombre
                self.raza = raza
                self.color = color
                self.edad = edad
                self.peso = peso
                self.tamano = tamano
                self.genero = genero
                self.tipo_pelo = tipo_pelo
                self.nivel_energia = nivel_energia
                self.dueno = dueno
                print(f"Nombredel perro: {self.nombre}")
                print(f"Raza: {self.raza}")
                print(f"Color: {self.color}")
                print(f"Edad: {self.edad}")
                print(f"Peso: {self.peso}")
                print(f"Tamaño: {self.tamano}")
                print(f"Género: {self.genero}")
                print(f"Tipo de pelo: {self.tipo_pelo}")
                print(f"Nivel de energía: {self.nivel_energia}")
                print(f"Dueño: {self.dueno}")
        def salta(self):
            print("el perro salta de felicidad")
        def comer(self):
            print("está comiendo sus croquetas")
        def correr(self):
            print("el corre por que vio a su dueño")
        def dormir(self):
            print("el se ha quedado dormido")
        def huele(self):
            print("el perro huele su comida")
perro_mascota = Perro("canelo", "pastor aleman", "negro con cafe", "6 meses", "13 Kg", "mediano", "hembra", "largo", "alto", "chora")
perro_mascota.salta()
perro_mascota.comer()
perro_mascota.correr()
perro_mascota.dormir()
perro_mascota.huele()
