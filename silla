class Silla:
        def _init_(self, color, anchura, altura, forma, material, peso_max, estilo, patas, marca, respaldo):
                self.color = color
                self.anchura = anchura
                self.altura = altura
                self.forma = forma
                self.material = material
                self.peso_max = peso_max
                self.estilo = estilo
                self.patas = patas
                self.marca = marca
                self.respaldo = respaldo

                print(f"Color: {self.color}")
                print(f"Anchura: {self.anchura}")
                print(f"Altura: {self.altura}")
                print(f"Forma: {self.forma}")
                print(f"Material: {self.material}")
                print(f"Peso máximo: {self.peso_max}")
                print(f"Estilo: {self.estilo}")
                print(f"Número de patas: {self.patas}")
                print(f"Marca: {self.marca}")
                print(f"Tipo de respaldo: {self.respaldo}")

        def sentarse(self):
                print("Alguien se ha sentado en la silla.")
        def limpiar(self):
                print("La silla está siendo limpiada.")
        def mover(self):
                print("La silla se está moviendo de lugar.")
        def ajustar_altura(self):
                print("La altura de la silla ha sido ajustada.")
        def girar(self):
                print("La silla está girando sobre su eje.")
silla_oficina = Silla("cafe", "0.50 m", "1 m", "Ergonómica", "Malla y Plástico", "100 Kg", "Ejecutivo", 5, "Herman Miller", "Ajustable")

silla_oficina.sentarse()
silla_oficina.limpiar()
silla_oficina.mover()
silla_oficina.ajustar_altura()
silla_oficina.girar()